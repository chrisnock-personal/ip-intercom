# Copy to .env and fill in before `podman-compose up -d --build`

# Required: this host's routed/LAN IP — rtpengine binds media here so
# endpoints on other subnets can reach it.
RTPENGINE_PUBLIC_IP=192.168.1.150

# Controller auth
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@intercom.local
ADMIN_PASSWORD=change-me

# Controller DB (defaults are fine for a local lab)
PGDATABASE=intercom
PGUSER=intercom_user
PGPASSWORD=intercom_pass

# CORS — tighten if the frontend isn't served from the same host
CORS_ORIGIN=*

# drachtio admin secret (pbx-core <-> its own control socket)
DRACHTIO_SECRET=cymru
