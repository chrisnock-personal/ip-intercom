# Build context is the repo root (see docker-compose.yml), so this can reach
# both controller/backend/ and the top-level migrations/ directory.
FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY controller/backend/package.json controller/backend/tsconfig.json ./
RUN npm install
COPY controller/backend/src ./src
RUN npm run build

FROM node:22-bookworm-slim
WORKDIR /app
# pg_dump/psql for the Database/Backup admin page (routes/admin.ts) — postgres
# is a separate container here (unlike Walk the Nxt Floor's single-container
# setup), so these connect over TCP rather than a local peer-auth socket.
# MUST be version-matched to the postgres:16-alpine server: bookworm's plain
# `postgresql-client` package installs v15, and pg_dump hard-refuses to run
# against a newer server ("aborting because of server version mismatch") —
# confirmed by boot-testing, not just a theoretical concern. PGDG's own apt
# repo is added here to get postgresql-client-16 specifically.
RUN apt-get update && apt-get install -y --no-install-recommends wget gnupg ca-certificates \
 && install -d /usr/share/postgresql-common/pgdg \
 && wget --quiet -O /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc https://www.postgresql.org/media/keys/ACCC4CF8.asc \
 && echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" > /etc/apt/sources.list.d/pgdg.list \
 && apt-get update && apt-get install -y --no-install-recommends postgresql-client-16 \
 && apt-get purge -y wget gnupg \
 && apt-get autoremove -y \
 && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY migrations ./migrations
ENV NODE_ENV=production
EXPOSE 3100
CMD ["node", "dist/index.js"]
