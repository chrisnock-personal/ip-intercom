# Build context is the repo root (see docker-compose.yml) so this stage can
# also reach the top-level turret/ app, served at /turret/ by the same nginx
# rather than standing up a second container for it.
FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY controller/frontend/package.json ./
RUN npm install
COPY controller/frontend/ .
RUN npm run build

FROM node:22-bookworm-slim AS turret-build
WORKDIR /app
COPY turret/package.json ./
RUN npm install
COPY turret/ .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY --from=turret-build /app/dist /usr/share/nginx/html/turret
COPY controller/frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
